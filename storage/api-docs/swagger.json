{
  "openapi": "3.0.0",
  "info": {
    "title": "SmartStock API",
    "description": "Warehouse Management System API with role-based access control",
    "version": "1.0.0",
    "contact": {
      "name": "SmartStock Dev Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Development Server"
    },
    {
      "url": "https://api.smartstock.com/api",
      "description": "Production Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Authorization header using Bearer scheme"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["admin", "magasinier", "client", "Supplier"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "sku": { "type": "string" },
          "quantity": { "type": "integer" },
          "price": { "type": "number" },
          "alert_threshold": { "type": "integer" },
          "category_id": { "type": "integer" },
          "warehouse_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Command": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string", "enum": ["pending", "approved", "received", "cancelled"] },
          "ordered_at": { "type": "string", "format": "date" },
          "total_cost": { "type": "number" },
          "client_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Supplier": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "address": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Warehouse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "address": { "type": "string" },
          "user_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Mouvement": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "type": { "type": "string", "enum": ["IN", "OUT", "ADJ"] },
          "quantity": { "type": "integer" },
          "note": { "type": "string" },
          "product_id": { "type": "integer" },
          "command_id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "triggered_at": { "type": "string", "format": "date-time" },
          "type": { "type": "string", "enum": ["LOW_STOCK", "DISCREPANCY", "ADJUSTMENT"] },
          "product_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Archive": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "product_id": { "type": "integer" },
          "quantity": { "type": "integer" },
          "user_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ],
  "paths": {
    "/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "role"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" },
                  "role": { "type": "string", "enum": ["admin", "magasinier", "client"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout",
        "description": "Invalidates the current JWT token.",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "Successfully logged out" },
          "500": { "description": "Failed to logout" }
        }
      }
    },
    "/user": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get current user profile",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "404": { "description": "User not found" }
        }
      },
      "put": {
        "tags": ["Authentication"],
        "summary": "Update current user profile",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Jane Doe" },
                  "email": { "type": "string", "format": "email", "example": "jane@example.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "500": { "description": "Failed to update user" }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List all products",
        "description": "Returns all products with their category and warehouse. Requires magasinier role.",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create a new product",
        "description": "Adds a product to the inventory. Automatically triggers low-stock alert check.",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "sku", "quantity", "price", "alert_threshold", "category_id", "warehouse_id"],
                "properties": {
                  "name": { "type": "string", "example": "Laptop Dell XPS 15" },
                  "sku": { "type": "string", "example": "DELL-XPS-15-001" },
                  "quantity": { "type": "integer", "example": 50 },
                  "price": { "type": "number", "example": 1299.99 },
                  "alert_threshold": { "type": "integer", "example": 10 },
                  "category_id": { "type": "integer", "example": 1 },
                  "warehouse_id": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Product created successfully" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product details",
        "description": "Returns a product with its category, warehouse, alerts, commands, and movements.",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Product details" },
          "404": { "description": "Product not found" }
        }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Update a product",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "sku": { "type": "string" },
                  "quantity": { "type": "integer" },
                  "price": { "type": "number" },
                  "alert_threshold": { "type": "integer" },
                  "category_id": { "type": "integer" },
                  "warehouse_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Product updated successfully" },
          "404": { "description": "Product not found" },
          "422": { "description": "Validation error" }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete a product",
        "description": "Deletes the product and dismisses all its active alerts.",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Product deleted successfully" },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "List all categories",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": {
            "description": "List of categories",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Categories"],
        "summary": "Create a new category",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "Electronics" },
                  "description": { "type": "string", "example": "Electronic devices" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Category created" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/categories/{id}": {
      "get": {
        "tags": ["Categories"],
        "summary": "Get category details",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Category details" },
          "404": { "description": "Category not found" }
        }
      },
      "put": {
        "tags": ["Categories"],
        "summary": "Update a category",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Category updated" },
          "404": { "description": "Category not found" }
        }
      },
      "delete": {
        "tags": ["Categories"],
        "summary": "Delete a category",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Category deleted" },
          "404": { "description": "Category not found" }
        }
      }
    },
    "/warehouses": {
      "get": {
        "tags": ["Warehouses"],
        "summary": "List all warehouses",
        "description": "Returns all warehouses with their products.",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "List of warehouses" }
        }
      },
      "post": {
        "tags": ["Warehouses"],
        "summary": "Create a new warehouse",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "address"],
                "properties": {
                  "name": { "type": "string", "example": "Main Warehouse" },
                  "address": { "type": "string", "example": "123 Industrial Ave, Casablanca" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Warehouse created" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/warehouses/{id}": {
      "get": {
        "tags": ["Warehouses"],
        "summary": "Get warehouse details",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Warehouse details" },
          "404": { "description": "Warehouse not found" }
        }
      },
      "put": {
        "tags": ["Warehouses"],
        "summary": "Update a warehouse",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "address": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Warehouse updated" },
          "404": { "description": "Warehouse not found" }
        }
      }
    },
    "/mouvements": {
      "get": {
        "tags": ["Mouvements"],
        "summary": "List all stock movements",
        "description": "Returns all movements with product, command, and user details.",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "List of movements" }
        }
      },
      "post": {
        "tags": ["Mouvements"],
        "summary": "Record a new stock movement",
        "description": "Creates a movement (IN/OUT/ADJ), updates product quantity, and triggers alert checks. ADJ type supports setting a new_quantity directly.",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type", "quantity", "product_id", "user_id"],
                "properties": {
                  "type": { "type": "string", "enum": ["IN", "OUT", "ADJ"], "example": "IN" },
                  "quantity": { "type": "integer", "minimum": 1, "example": 25 },
                  "note": { "type": "string", "example": "Received from supplier shipment" },
                  "product_id": { "type": "integer", "example": 1 },
                  "command_id": { "type": "integer", "example": 1 },
                  "user_id": { "type": "integer", "example": 1 },
                  "new_quantity": { "type": "integer", "description": "Only used for ADJ type to set absolute quantity", "example": 100 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Movement recorded, product updated, alerts checked" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/mouvements/{id}": {
      "get": {
        "tags": ["Mouvements"],
        "summary": "Get movement details",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Movement details" },
          "404": { "description": "Movement not found" }
        }
      },
      "put": {
        "tags": ["Mouvements"],
        "summary": "Update a movement",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["IN", "OUT", "ADJ"] },
                  "quantity": { "type": "integer", "minimum": 1 },
                  "note": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Movement updated" },
          "404": { "description": "Movement not found" }
        }
      }
    },
    "/commands": {
      "get": {
        "tags": ["Commands"],
        "summary": "List all commands/orders",
        "description": "Returns all commands with client and product details.",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "List of commands" }
        }
      },
      "post": {
        "tags": ["Commands"],
        "summary": "Create a new command/order",
        "description": "Creates a command with attached products. Total cost is auto-calculated.",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ordered_at", "client_id", "products"],
                "properties": {
                  "ordered_at": { "type": "string", "format": "date", "example": "2026-04-14" },
                  "client_id": { "type": "integer", "example": 1 },
                  "products": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["product_id", "quantity", "unit_price"],
                      "properties": {
                        "product_id": { "type": "integer", "example": 1 },
                        "quantity": { "type": "integer", "example": 5 },
                        "unit_price": { "type": "number", "example": 1299.99 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Command created successfully" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/commands/{id}": {
      "get": {
        "tags": ["Commands"],
        "summary": "Get command details",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Command details" },
          "404": { "description": "Command not found" }
        }
      },
      "put": {
        "tags": ["Commands"],
        "summary": "Update command status",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["pending", "approved", "received", "cancelled"], "example": "approved" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Command updated" },
          "404": { "description": "Command not found" }
        }
      }
    },
    "/suppliers": {
      "get": {
        "tags": ["Suppliers"],
        "summary": "List all suppliers",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "List of suppliers" }
        }
      },
      "post": {
        "tags": ["Suppliers"],
        "summary": "Create a new supplier",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "Tech Supplies Inc." },
                  "email": { "type": "string", "format": "email", "example": "contact@techsupplies.com" },
                  "phone": { "type": "string", "example": "+212600000000" },
                  "address": { "type": "string", "example": "456 Commerce St, Rabat" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Supplier created" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/suppliers/{id}": {
      "get": {
        "tags": ["Suppliers"],
        "summary": "Get supplier details",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Supplier details" },
          "404": { "description": "Supplier not found" }
        }
      },
      "put": {
        "tags": ["Suppliers"],
        "summary": "Update a supplier",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "phone": { "type": "string" },
                  "address": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Supplier updated" },
          "404": { "description": "Supplier not found" }
        }
      },
      "delete": {
        "tags": ["Suppliers"],
        "summary": "Delete a supplier",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
